# Trimora Environment Configuration

# Storage
TRIMORA_STORAGE_ROOT=./storage
TRIMORA_JOBS_ROOT=./storage/jobs

# Workers
TRIMORA_MAX_TRANSCRIPTION_WORKERS=15
TRIMORA_MAX_FEATURE_WORKERS=15
TRIMORA_MAX_CLIP_WORKERS=8

# Chunking
TRIMORA_MIN_CHUNK_SECONDS=30
TRIMORA_MAX_CHUNK_SECONDS=120
TRIMORA_OVERLAP_SECONDS=2

# Transcription
TRIMORA_TRANSCRIPTION_PROVIDER=stub
TRIMORA_TRANSCRIPTION_TIMEOUT=600

# CORS
TRIMORA_CORS_ORIGINS=*

# Frontend
VITE_API_BASE_URL=http://localhost:8000

# API Keys — each key on its own line
# Primary: Groq (whisper-large-v3-turbo, Llama 3.1)
# Multiple keys enable round-robin load balancing via ProviderRouter
GROQ_API_KEY_1=
# GROQ_API_KEY_2=
# GROQ_API_KEY_3=

# Fallback: Gemini (gemini-2.0-flash)
GEMINI_API_KEY=
